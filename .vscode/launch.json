{
  "version": "0.2.0",
  "configurations": [  
    {
      "name": "🟦 Run API",
      "request": "launch",
      "type": "node",
      "cwd": "${workspaceFolder}/packages/core",
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "-A",
        "--watch",
        "--inspect=127.0.0.1:7009",
        "main.ts"
      ],
      "attachSimplePort": 7009,
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
    },
    {
      "name": "🟥 Run App",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8081",
      "webRoot": "${workspaceFolder}/packages/app",
      "preLaunchTask": "app:start",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///./*": "${webRoot}/*"
      }
    },
    {
      "name": "🟨 Run Web",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:7002",
      "webRoot": "${workspaceFolder}/packages/web/app",
      "preLaunchTask": "web:start"
    }
  ],
  "compounds": [
    {
      "name": "🟩 Run App",
      "configurations": [
        "🟦 Run API",
        "🟥 Run App",
      ],
      "stopAll": true,
      // "preLaunchTask": "kill:all"
    },
    {
      "name": "🟩 Run Web",
      "configurations": [
        "🟦 Run API",
        "🟨 Run Web",
      ],
      "stopAll": true,
      // "preLaunchTask": "kill:all"
    }
  ]
}