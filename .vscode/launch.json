{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🟦 Run API",
      "request": "attach",
      "type": "node",
      "port": 7009,
      "preLaunchTask": "start:core",
      "restart": true,
      "envFile": "${workspaceFolder}/.env",
    },
    {
      "name": "🟥 Run App",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8081",
      "webRoot": "${workspaceFolder}/packages/app",
      "preLaunchTask": "start:app",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///./*": "${webRoot}/*"
      }
    },
    {
      "name": "🟨 Run Web",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:7002",
      "webRoot": "${workspaceFolder}/packages/web/app",
      "preLaunchTask": "start:web"
    }
  ],
  "compounds": [
    {
      "name": "🟩 Run App",
      "configurations": [
        "🟦 Run API",
        "🟥 Run App",
      ],
      "stopAll": true,
    },
    {
      "name": "🟩 Run Web",
      "configurations": [
        "🟦 Run API",
        "🟨 Run Web",
      ],
      "stopAll": true,
    }
  ]
}