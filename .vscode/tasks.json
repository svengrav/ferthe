{
  "version": "2.0.0",
  "tasks": [
    // Tasks to start the development environment
    {
      "label": "start:core",
      "type": "shell",
      "command": "deno task dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/core"
      },
      "dependsOrder": "sequence",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Oak server starting",
        }
      }
    },
    {
      "label": "start:app",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/app"
      },
      "dependsOn": [
        "start:storage"
      ],
      "dependsOrder": "sequence",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Metro Bundler",
          "endsPattern": "Logs for your project will appear below"
        }
      }
    },
    {
      "label": "start:storage",
      "type": "shell",
      "command": "deno run --allow-all ${workspaceFolder}/tools/start-localstorage.ts",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*tsx.*localStorageServer|Starting",
          "endsPattern": "Local Storage Server running|running on|Server running|listening"
        }
      }
    },
    {
      "label": "start:web",
      "type": "shell",
      "command": "deno run dev",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}/packages/web"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE|starting",
          "endsPattern": "ready in|Local:|http://localhost"
        }
      }
    },
    {
      "label": "test:core",
      "type": "shell",
      "command": "deno task test",
      "options": {
        "cwd": "${workspaceFolder}/packages/core"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "test:app",
      "type": "shell",
      "command": "npm run test",
      "options": {
        "cwd": "${workspaceFolder}/packages/app"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "check:app",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "options": {
        "cwd": "${workspaceFolder}/packages/app"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "check:core",
      "type": "shell",
      "command": "deno check",
      "options": {
        "cwd": "${workspaceFolder}/packages/core"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "check:web",
      "type": "shell",
      "command": "deno check",
      "options": {
        "cwd": "${workspaceFolder}/packages/web"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "check:all",
      "dependsOn": [
        "check:app",
        "check:core",
        "check:web"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "deploy:web",
      "type": "shell",
      "command": "cd ${workspaceFolder}/packages/web && bash deploy.bash",
      "group": "build",
    },
    {
      "label": "kill:all",
      "type": "shell",
      "command": "fuser -k 7000/tcp 7001/tcp 7002/tcp 7003/tcp 8081/tcp 7009/tcp 2>/dev/null; pkill -f 'deno.*main.ts' 2>/dev/null; pkill -f 'deno.*--inspect' 2>/dev/null; pkill -f 'metro' 2>/dev/null; exit 0",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
  ]
}