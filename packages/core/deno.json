{
  "tasks": {
    "dev": "deno run -A --watch --inspect=127.0.0.1:7009 ./main.ts",
    "check": "deno check",
    "test": "deno test -A --ignore=test/smoke.test.ts",
    "test:smoke": "deno test -A test/smoke.test.ts",
    "lint": "deno lint"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-sloppy-imports",
        "no-explicit-any"
      ]
    }
  },
  "imports": {
    "@/": "./",
    "@core/": "./",
    "@shared/": "../shared/",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@azure/data-tables": "npm:@azure/data-tables@^13.3.2",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.99.1",
    "gray-matter": "npm:gray-matter@^4.0.3",
    "sharp": "npm:sharp@^0.34.5",
    "supabase": "npm:supabase@^2.78.1",
    "zod": "npm:zod@^4.3.6",
    "@azure/storage-blob": "npm:@azure/storage-blob@^12.31.0",
    "@azure/cosmos": "npm:@azure/cosmos@^4.9.1",
    "@azure/identity": "npm:@azure/identity@^4.13.0",
    "@azure/keyvault-secrets": "npm:@azure/keyvault-secrets@^4.10.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "dotenv": "npm:dotenv@^16.6.1",
    "twilio": "npm:twilio@^5.13.0",
    "oak": "jsr:@oak/oak@^17.2.0",
    "path": "npm:path@^0.12.7",
    "fs": "node:fs/promises",
    "jimp": "npm:jimp@0.22.12"
  }
}