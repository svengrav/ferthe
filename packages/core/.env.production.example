# Ferthe Core API - Production Environment Variables
# Copy this file to .env.production and fill in the values

# ============================================
# Azure Key Vault (recommended for production)
# ============================================
# If set, secrets will be loaded from Azure Key Vault
# Leave empty to use environment variables directly
AZURE_KEYVAULT_NAME=kv-ferthe-core

# ============================================
# Core Configuration
# ============================================
CORE_PORT=7000

# ============================================
# Secrets (if not using Key Vault)
# ============================================
JWT_SECRET=your-jwt-secret-here
PHONE_HASH_SALT=your-phone-hash-salt-here

# ============================================
# Azure Resources
# ============================================
# Cosmos DB connection string (or use Azure Table Storage)
COSMOS_CONNECTION_STRING=AccountEndpoint=https://xxx.documents.azure.com:443/;AccountKey=xxx

# Azure Storage (Blob Storage for images/resources)
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net

# Azure Maps API Key
AZURE_MAPS_KEY=your-azure-maps-key

# ============================================
# Twilio (SMS Verification)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Google Services
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Firebase (Push Notifications)
# ============================================
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Firebase Service Account (JSON string)
# Format: {"client_email":"xxx","private_key":"xxx","project_id":"xxx"}
FIREBASE_SERVICE_ACCOUNT={}
