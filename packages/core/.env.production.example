# Ferthe Core API - Production Environment Variables
# Copy this file to .env and set these values in your production environment

# ============================================
# Azure Key Vault (REQUIRED for production)
# ============================================
# All secrets are loaded from Key Vault as a single JSON-Secret (json-ferthe-core-config-v1)
# Requires Service Principal authentication

AZURE_CLIENT_SECRET=your-service-principal-client-secret
AZURE_KEYVAULT_NAME=kv-ferthe-core

# Service Principal Details (for reference):
# - Client ID: f3bf916d-0ebf-476e-9ccb-98808c7e1038
# - Tenant ID: 16b3c013-d300-468d-ac64-7eda0820b6d3
# - Secret Name: json-ferthe-core-config-v1

# ============================================
# Core Configuration
# ============================================
PORT=7000
HOST=0.0.0.0
PRODUCTION=true
